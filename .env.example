# ========================================
# SERVIDOR (Cortex Multimodal Proxy v3)
# ========================================
PORT=7777
LOG_LEVEL=info

# ========================================
# BRAIN MODE (REQUIRED para elegir provider)
# ========================================
# opencode → solo brains OpenCode Go + MiMo V2.5 vision.
#            Default si no se setea (equivalente a auto con solo OPENCODE_GO_API_KEY).
# deepseek → solo brains DeepSeek V4 Pro/Flash (tu cuenta) + MiniMax M3 vision (si MINIMAX_API_KEY).
# hybrid   → ambos providers activos; DeepSeek bajo IDs proxy/local-deepseek-v4-*.
# auto     → elige opencode o deepseek segun las keys presentes (deepseek gana si esta; warning si OPENCODE_GO_API_KEY tambien esta).
BRAIN_MODE=auto

# ========================================
# OPENCODE GO (brains + MiMo V2.5 senses)
# ========================================
# Requerido para BRAIN_MODE=opencode o hybrid
# Obten tu API key en https://opencode.ai/auth (suscripcion Go: $10/mes)
OPENCODE_GO_API_KEY=sk-your-opencode-go-key
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_GO_TIMEOUT_MS=120000

# ========================================
# DEEPSEEK (brain alternativo)
# ========================================
# Requerido para BRAIN_MODE=deepseek o hybrid.
# Cuando deepseek, las IDs proxy/deepseek-v4-{pro,flash} se registran apuntando a TU cuenta.
# Cuando hybrid, se registran como proxy/local-deepseek-v4-{pro,flash} (OpenCode Go flavor queda bajo proxy/deepseek-v4-{pro,flash}).
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=120000

# ========================================
# MINIMAX M3 VISION (opcional, primario si esta presente)
# ========================================
# Vision alternativo a MiMo V2.5. Si esta presente, se usa en modos deepseek y hybrid.
# Si no, vision queda en MiMo V2.5 (opencode/hybrid) o deshabilitada (deepseek puro).
MINIMAX_API_KEY=your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_TIMEOUT_MS=300000
# Pricing for MiniMax-M3 passthrough (USD per 1M tokens). Used only for
# dashboard cost estimation. Default 0 = dashboard shows $0 (backward
# compat). Set to your real MiniMax M3 per-token rates if you want
# cost tracking in /dashboard.
MINIMAX_INPUT_PRICE=0
MINIMAX_OUTPUT_PRICE=0
SENSES_MODEL=mimo-v2.5
SENSES_TIMEOUT_MS=120000

# ========================================
# CLAUDE CODE - Mapeo de modelos
# ========================================
# haiku/sonnet/opus en Claude Code se mapean a estos modelos internos
CLAUDE_HAIKU_MODEL=mimo-v2.5
CLAUDE_SONNET_MODEL=proxy/deepseek-v4-pro
CLAUDE_OPUS_MODEL=proxy/glm-5.2

# ========================================
# GEMINI (Fallback para audio/video/PDF grandes)
# ========================================
# Opcional: solo se usa si hay contenido de audio/video o PDFs >1MB
# Si no configuras esta key, esos tipos de contenido daran error
GEMINI_API_KEY=tu_api_key_de_google
GEMINI_MODEL=gemini-2.5-flash

# ========================================
# CACHE
# ========================================
CACHE_ENABLED=true
CACHE_DIR=./cache
CACHE_TTL_DAYS=7
CACHE_MAX_ENTRIES=1000

# ========================================
# LIMITES
# ========================================
MAX_FILE_SIZE_MB=50
MAX_IMAGES_PER_REQUEST=999

# ========================================
# PROCESAMIENTO PDF (OPCIONAL)
# ========================================
PDF_LOCAL_PROCESSING=true
PDF_LOCAL_MAX_SIZE_MB=1

# ========================================
# DASHBOARD (informativo: consumo, logs, cache, ops)
# ========================================
# Mismo Express, mismo puerto 7777, namespace /dashboard/* y /v1/dashboard/snapshot.
# Sin auth — consistente con el resto del proxy. Polling 10s desde el cliente.
DASHBOARD_ENABLED=true
DASHBOARD_RETENTION_DAYS=90
DASHBOARD_POLL_INTERVAL_MS=10000
DASHBOARD_LOG_TAIL_LINES=200
DASHBOARD_DB_PATH=./data/dashboard.db
